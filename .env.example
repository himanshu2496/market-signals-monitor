# ─────────────────────────────────────────────────────────────
# Market Signals — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env for local testing:
#   cp .env.example .env
#
# NEVER commit .env to git. Add it to .gitignore.
# In production (GitHub Actions), set these as repository Secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────────

# Slack Incoming Webhook URL for #market-signals-industry
# How to get: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_INDUSTRY=paste-your-industry-webhook-url-here

# Slack Incoming Webhook URL for #market-signals-intel
# Create a second webhook for a different channel (same app or a new one)
SLACK_WEBHOOK_INTEL=paste-your-intel-webhook-url-here

# NewsAPI.org free tier key (100 requests/day)
# Register at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Google Gemini API key — used for AI relevance filtering and action summaries
# Free tier: 1,500 requests/day. Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
